/* ===================== VOICE ===================== */
let zhVoice=null,esVoice=null;
function initVoices(){
  const vs=speechSynthesis.getVoices();
  zhVoice=vs.find(v=>v.lang.startsWith('zh-CN'))||vs.find(v=>v.lang.startsWith('zh'))||null;
  esVoice=vs.find(v=>v.lang.startsWith('es-'))||null;
  const w=document.getElementById('voice-warn');
  if(w) w.textContent=zhVoice?'✓ '+zhVoice.name.split(' ')[0]:'⚠️ Sin voz china';
  renderTopbarUser();
}
speechSynthesis.onvoiceschanged=initVoices;
setTimeout(initVoices,500);
function speakText(text,voice,lang,rate){
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  if(voice){u.voice=voice;u.lang=voice.lang;}else u.lang=lang;
  u.rate=rate||0.85;
  speechSynthesis.speak(u);
  return u;
}
function speakPhraseTwice(text,rate,onDone){
  speechSynthesis.cancel();
  const u1=new SpeechSynthesisUtterance(text);
  if(zhVoice){u1.voice=zhVoice;u1.lang=zhVoice.lang;}else u1.lang='zh-CN';
  u1.rate=rate||0.75;
  u1.onend=()=>setTimeout(()=>{
    const u2=new SpeechSynthesisUtterance(text);
    if(zhVoice){u2.voice=zhVoice;u2.lang=zhVoice.lang;}else u2.lang='zh-CN';
    u2.rate=rate||0.75;
    u2.onend=()=>{if(onDone)onDone();};
    speechSynthesis.speak(u2);
  },700);
  speechSynthesis.speak(u1);
}

