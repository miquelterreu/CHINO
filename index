async function sbFetch(path,opts={}){
  const headers={'apikey':SUPABASE_ANON,'Content-Type':'application/json',...(opts.headers||{})};
  const session=getSession();
  if(session) headers['Authorization']='Bearer '+session.access_token;
  const r=await fetch(SUPABASE_URL+path,{...opts,headers});
  if(!r.ok){const e=await r.json().catch(()=>({}));throw new Error(e.error_description||e.message||r.status);}
  const ct=r.headers.get('content-type')||'';
  return ct.includes('json')?r.json():null;
}

/* ===================== SESSION ===================== */
function getSession(){try{return JSON.parse(localStorage.getItem('sb-session'));}catch(e){return null;}}
function saveSession(s){if(s)localStorage.setItem('sb-session',JSON.stringify(s));else localStorage.removeItem('sb-session');}
function getCurrentUser(){const s=getSession();return s?s.user:null;}

function renderTopbarUser(){
  const u=getCurrentUser();
  const el=document.getElementById('topbar-user');
  if(!el)return;
  if(u){
    const name=u.user_metadata&&u.user_metadata.display_name?u.user_metadata.display_name:u.email.split('@')[0];
    const initials=name.charAt(0).toUpperCase();
    el.innerHTML=`<div class="user-chip"><div class="user-avatar">${initials}</div><span class="user-name-pill">${name}</span></div><button class="btn-logout" onclick="doLogout()">Salir</button>`;
  } else {
    el.innerHTML=`<button class="btn-login" onclick="openAuthModal()">Entrar 👤</button>`;
  }
  updateReviewUI();
}

function updateReviewUI(){
  const u=getCurrentUser();
  const prompt=document.getElementById('review-login-prompt');
  const form=document.getElementById('review-form');
  if(!prompt||!form)return;
  if(u){prompt.style.display='none';form.className='review-form visible';}
  else{prompt.style.display='block';form.className='review-form';}
}

/* ===================== AUTH ===================== */
function openAuthModal(){document.getElementById('auth-modal').className='modal-overlay on';}
function closeAuthModal(e){if(e&&e.target!==document.getElementById('auth-modal'))return;document.getElementById('auth-modal').className='modal-overlay';}
function switchAuthTab(t){
  document.getElementById('tab-login').className='modal-tab'+(t==='login'?' on':'');
  document.getElementById('tab-register').className='modal-tab'+(t==='register'?' on':'');
  document.getElementById('auth-login-form').style.display=t==='login'?'flex':'none';
  document.getElementById('auth-register-form').style.display=t==='register'?'flex':'none';
  document.getElementById('login-msg').textContent='';
  document.getElementById('reg-msg').textContent='';
}

async function doLogin(){
  const email=document.getElementById('login-email').value.trim();
  const pass=document.getElementById('login-pass').value;
  const msg=document.getElementById('login-msg');
  if(!email||!pass){msg.textContent='Rellena email y contraseña.';return;}
  msg.textContent='Entrando…';msg.className='modal-msg';
  try{
    const data=await sbFetch('/auth/v1/token?grant_type=password',{method:'POST',body:JSON.stringify({email,password:pass})});
    saveSession(data);
    msg.textContent='¡Bienvenido/a!';msg.className='modal-msg ok';
    setTimeout(()=>{closeAuthModal();renderTopbarUser();if(document.getElementById('sec-reviews').classList.contains('on'))renderReviews();},600);
  }catch(e){msg.textContent='Error: '+e.message;msg.className='modal-msg';}
}

async function doRegister(){
  const name=document.getElementById('reg-name').value.trim();
  const email=document.getElementById('reg-email').value.trim();
  const pass=document.getElementById('reg-pass').value;
  const msg=document.getElementById('reg-msg');
  if(!name){msg.textContent='Escribe tu nombre.';return;}
  if(!email){msg.textContent='Escribe tu email.';return;}
  if(pass.length<6){msg.textContent='La contraseña debe tener al menos 6 caracteres.';return;}
  msg.textContent='Creando cuenta…';msg.className='modal-msg';
  try{
    const data=await sbFetch('/auth/v1/signup',{method:'POST',body:JSON.stringify({email,password:pass,data:{display_name:name}})});
    if(data.user&&data.access_token){
      saveSession(data);
      msg.textContent='¡Cuenta creada! Bienvenido/a, '+name+'!';msg.className='modal-msg ok';
      setTimeout(()=>{closeAuthModal();renderTopbarUser();},700);
    } else {
      msg.textContent='Cuenta creada. Revisa tu email para confirmar.';msg.className='modal-msg ok';
    }
  }catch(e){msg.textContent='Error: '+e.message;msg.className='modal-msg';}
}

async function doLogout(){
  const session=getSession();
  if(session){try{await sbFetch('/auth/v1/logout',{method:'POST'});}catch(e){}}
  saveSession(null);
  renderTopbarUser();
}

async function initAuth(){
  const session=getSession();
  if(!session)return;
  try{
    const data=await sbFetch('/auth/v1/token?grant_type=refresh_token',{method:'POST',body:JSON.stringify({refresh_token:session.refresh_token})});
    saveSession(data);
  }catch(e){saveSession(null);}
  renderTopbarUser();
}

/* ===================== RESEÑAS (SUPABASE) ===================== */
let reviewStars=0;
function setStars(n){
  reviewStars=n;
  document.querySelectorAll('.star-btn').forEach((s,i)=>s.className='star-btn'+(i<n?' on':''));
}
async function submitReview(){
  const u=getCurrentUser();
  if(!u){alert('Inicia sesión para dejar una reseña.');return;}
  const text=document.getElementById('review-text').value.trim();
  if(!reviewStars){alert('Elige una puntuación ⭐');return;}
  if(!text){alert('Escribe algo antes de enviar 😊');return;}
  const name=u.user_metadata&&u.user_metadata.display_name?u.user_metadata.display_name:u.email.split('@')[0];
  try{
    await sbFetch('/rest/v1/reviews',{method:'POST',headers:{'Prefer':'return=minimal'},body:JSON.stringify({stars:reviewStars,text,author:name,user_id:u.id})});
    document.getElementById('review-text').value='';
    setStars(0);reviewStars=0;
    renderReviews();
  }catch(e){alert('Error al enviar: '+e.message);}
}
async function renderReviews(){
  updateReviewUI();
  const list=document.getElementById('reviews-list');
  const empty=document.getElementById('reviews-empty');
  list.innerHTML='<div style="text-align:center;color:#ccc;padding:1rem;font-size:13px;">Cargando reseñas…</div>';
  try{
    const reviews=await sbFetch('/rest/v1/reviews?select=*&order=created_at.desc',{headers:{'Accept':'application/json'}});
    list.innerHTML='';
    if(!reviews||!reviews.length){empty.style.display='block';return;}
    empty.style.display='none';
    reviews.forEach(r=>{
      const el=document.createElement('div');
      el.className='review-item';
      const date=new Date(r.created_at).toLocaleDateString('es-ES');
      el.innerHTML=`<div class="review-item-top"><div class="review-item-stars">${'⭐'.repeat(r.stars)}</div><div class="review-item-meta"><div class="review-item-author">${r.author||'Anónimo'}</div><div class="review-item-date">${date}</div></div></div><div class="review-item-text">${r.text}</div>`;
      list.appendChild(el);
    });
  }catch(e){list.innerHTML='<div style="text-align:center;color:#ccc;padding:1rem;font-size:13px;">Sin conexión a Supabase.<br>Las reseñas necesitan internet.</div>';}
}

