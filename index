function getActivePhrases(){return PHRASES.filter((_,i)=>selectedPhrases.has(i));}
function buildPhraseSelector(){
  const list=document.getElementById('phrase-list');list.innerHTML='';
  PHRASES.forEach((p,i)=>{
    const item=document.createElement('div');
    item.className='phrase-item'+(selectedPhrases.has(i)?' selected':'');
    item.id='ps-item-'+i;
    const hEsc=p.h.replace(/'/g,"\\'");
    item.innerHTML=`<div class="phrase-item-check">${selectedPhrases.has(i)?'✓':''}</div><div class="phrase-item-text"><div class="phrase-item-h">${p.h}</div><div class="phrase-item-es">${p.es}</div></div><button class="phrase-item-play" onclick="event.stopPropagation();speakText('${hEsc}',zhVoice,'zh-CN',0.75)">🔊</button>`;
    item.onclick=()=>togglePhraseSelection(i);
    list.appendChild(item);
  });
}
function togglePhraseSelection(i){
  selectedPhrases.has(i)?selectedPhrases.delete(i):selectedPhrases.add(i);
  const item=document.getElementById('ps-item-'+i);
  const check=item.querySelector('.phrase-item-check');
  if(selectedPhrases.has(i)){item.className='phrase-item selected';check.textContent='✓';}
  else{item.className='phrase-item';check.textContent='';}
}
function psSelectAll(){PHRASES.forEach((_,i)=>selectedPhrases.add(i));buildPhraseSelector();}
function psSelectNone(){selectedPhrases.clear();buildPhraseSelector();}
function applySelection(){
  const active=getActivePhrases();
  if(!active.length){alert('Selecciona al menos una frase.');return;}
  toggleSelector(false);buildPhraseDeck(active);
}
function toggleSelector(forceClose){
  if(forceClose===false)selectorOpen=false;else selectorOpen=!selectorOpen;
  document.getElementById('phrase-selector').className='phrase-selector'+(selectorOpen?' on':'');
  document.getElementById('sel-toggle-btn').textContent=selectorOpen?'✕ Cerrar':'☰ Seleccionar';
}
function buildPhraseDeck(src){
  phDeck=shuffle([...src]);phIdx=0;phOk=0;phNo=0;phWrong=[];phFlipped=false;
  updatePhraseStats();
  document.getElementById('ph-done-box').style.display='none';
  document.getElementById('ph-actions').style.display='flex';
  showPhraseCard();
}
function setPhraseMode(m){
  phraseMode=m;
  ['listen','shadow','esp'].forEach(x=>document.getElementById('pm-'+x).className='mb'+(m===x?' on':''));
  shadowActive=m==='shadow';
  document.getElementById('shadow-bar').className='shadow-bar'+(shadowActive?' on':'');
  showPhraseCard();
}
function stopShadow(){setPhraseMode('listen');}
function showPhraseCard(){
  if(phIdx>=phDeck.length){showPhraseDone();return;}
  const c=phDeck[phIdx];phFlipped=false;
  document.getElementById('ph-ci').className='card-inner';
  if(phraseMode==='esp'){
    document.getElementById('ph-icon').style.display='none';
    document.getElementById('ph-hanzi').textContent=c.es;
    document.getElementById('ph-hanzi').style.fontSize='15px';
    document.getElementById('ph-hint').textContent='Toca para ver en chino';
  } else {
    document.getElementById('ph-icon').style.display='block';
    document.getElementById('ph-icon').textContent=shadowActive?'🎙️':'🔊';
    document.getElementById('ph-hanzi').textContent=c.h;
    document.getElementById('ph-hanzi').style.fontSize='34px';
    document.getElementById('ph-hint').textContent=shadowActive?'Escucha → repite → toca':'Toca para ver el significado';
  }
  document.getElementById('ph-esp').textContent=c.es;
  document.getElementById('ph-pinyin').textContent=c.p;
  document.getElementById('ph-hanzi-back').textContent=c.h;
  const pct=Math.round(phIdx/phDeck.length*100);
  document.getElementById('ph-prog-fill').style.width=pct+'%';
  document.getElementById('ph-prog-label').textContent='Frase '+(phIdx+1)+' de '+phDeck.length;
  document.getElementById('ph-s-left').textContent=phDeck.length-phIdx;
  if(phraseMode!=='esp') setTimeout(()=>speakPhraseTwice(c.h,0.75),400);
}
function flipPhrase(){
  phFlipped=!phFlipped;
  document.getElementById('ph-ci').className='card-inner'+(phFlipped?' flipped':'');
}
function repeatPhrase(){
  if(phIdx>=phDeck.length)return;
  const btn=document.getElementById('btn-phrase-repeat');
  btn.classList.add('playing');
  speakPhraseTwice(phDeck[phIdx].h,0.75,()=>btn.classList.remove('playing'));
}
function repeatPhraseSlow(){
  if(phIdx>=phDeck.length)return;
  const btn=document.getElementById('btn-phrase-slow');
  btn.classList.add('playing');
  speakPhraseTwice(phDeck[phIdx].h,0.5,()=>btn.classList.remove('playing'));
}
function phraseAnswer(knew){
  if(!phFlipped){flipPhrase();return;}
  if(knew)phOk++;else{phNo++;phWrong.push(phDeck[phIdx]);}
  phIdx++;updatePhraseStats();showPhraseCard();
}
function phraseSkip(){
  if(!phFlipped){flipPhrase();return;}
  phWrong.push(phDeck[phIdx]);phNo++;phIdx++;updatePhraseStats();showPhraseCard();
}
function updatePhraseStats(){
  document.getElementById('ph-s-ok').textContent=phOk;
  document.getElementById('ph-s-no').textContent=phNo;
  document.getElementById('ph-s-left').textContent=Math.max(0,phDeck.length-phIdx);
}
function showPhraseDone(){
  speechSynthesis.cancel();
  document.getElementById('ph-done-box').style.display='block';
  document.getElementById('ph-actions').style.display='none';
  document.getElementById('ph-prog-fill').style.width='100%';
  document.getElementById('ph-done-msg').textContent='Sabías '+phOk+' de '+phDeck.length+'. '+(phWrong.length?'Tienes '+phWrong.length+' para repasar.':'¡Perfecto! 🌟');
}
function restartPhrases(t){
  document.getElementById('ph-done-box').style.display='none';
  document.getElementById('ph-actions').style.display='flex';
  buildPhraseDeck(t==='wrong'&&phWrong.length?phWrong:getActivePhrases());
}

/* ===================== PRONUNCIACIÓN ===================== */
let pronSource=ALLVOCAB,pronActiveCats=new Set(),selectedPronCard=null;

function setPronDs(ds){
  ['all','t1','t2','t3','t4'].forEach(k=>document.getElementById('pds-'+k).className='ds-btn'+(k===ds?' on':''));
  pronSource=DATASETS[ds]||ALLVOCAB;
  buildPronCats();
}
function buildPronCats(){
  const sorted=[...pronSource].sort((a,b)=>a.h.localeCompare(b.h,'zh'));
  pronSource=sorted;
  const allC=[...new Set(pronSource.map(x=>x.cat))].sort();
  pronActiveCats=new Set(allC);
  const row=document.getElementById('pron-cats');row.innerHTML='';
  const allBtn=document.createElement('button');
  allBtn.className='pron-cat-btn on';allBtn.id='pc-ALL';allBtn.textContent='Todas';
  allBtn.onclick=()=>{
    const on=pronActiveCats.size===allC.length;
    pronActiveCats=on?new Set():new Set(allC);
    allC.forEach(c=>{const b=document.getElementById('pc-'+c);if(b)b.className='pron-cat-btn'+(pronActiveCats.has(c)?' on':'');});
    allBtn.className='pron-cat-btn'+(pronActiveCats.size===allC.length?' on':'');
    renderGrid();
  };
  row.appendChild(allBtn);
  allC.forEach(cat=>{
    const b=document.createElement('button');
    b.className='pron-cat-btn on';b.id='pc-'+cat;b.textContent=cat;
    b.onclick=()=>{
      pronActiveCats.has(cat)?pronActiveCats.delete(cat):pronActiveCats.add(cat);
      b.className='pron-cat-btn'+(pronActiveCats.has(cat)?' on':'');
      document.getElementById('pc-ALL').className='pron-cat-btn'+(pronActiveCats.size===allC.length?' on':'');
      renderGrid();
    };
    row.appendChild(b);
  });
  renderGrid();
}
function renderGrid(){
  const q=(document.getElementById('pron-search').value||'').toLowerCase();
  const filtered=pronSource.filter(x=>{
    if(!pronActiveCats.has(x.cat))return false;
    if(q&&!x.h.includes(q)&&!x.es.toLowerCase().includes(q)&&!x.p.toLowerCase().includes(q))return false;
    return true;
  });
  const grid=document.getElementById('pron-grid');
  const empty=document.getElementById('pron-empty');
  grid.innerHTML='';
  empty.style.display=filtered.length?'none':'block';
  filtered.forEach(item=>{
    const card=document.createElement('div');
    card.className='pron-card';
    card.innerHTML=`<div class="ph">${item.h}</div><div class="pp">${item.p}</div><div class="pe">${item.es}</div>`;
    card.onclick=()=>selectPron(item,card);
    grid.appendChild(card);
  });
}
function selectPron(item,cardEl){
  if(selectedPronCard) selectedPronCard.classList.remove('active');
  selectedPronCard=cardEl;cardEl.classList.add('active');
  document.getElementById('pd-hanzi').textContent=item.h;
  document.getElementById('pd-pinyin').textContent=item.p;
  document.getElementById('pd-cat').textContent=item.cat;
  document.getElementById('pd-esp').textContent=item.es;
  document.getElementById('pron-detail').className='pron-detail on';
  speakText(item.h,zhVoice,'zh-CN',0.85);
  document.getElementById('pron-detail').scrollIntoView({behavior:'smooth',block:'nearest'});
}
function pronSpeak(type){
  const h=document.getElementById('pd-hanzi').textContent;
  const es=document.getElementById('pd-esp').textContent;
  if(!h||h==='—')return;
  let u;
  if(type==='zh') u=speakText(h,zhVoice,'zh-CN',0.85);
  else if(type==='es') u=speakText(es,esVoice,'es-ES',0.85);
  else u=speakText(h,zhVoice,'zh-CN',0.5);
  const btnId=type==='es'?'pd-btn-es':type==='slow'?'pd-btn-slow':'pd-btn-zh';
  const btn=document.getElementById(btnId);
  if(btn){btn.classList.add('playing');if(u)u.onend=()=>btn.classList.remove('playing');}
}

