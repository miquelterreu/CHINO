/* ===================== FICHAS ===================== */
let currentSource=T1,currentDs='t1';
let deck=[],idx=0,flipped=false,mode='hanzi',ok=0,no=0,wrong=[],autoplay=true;
let activeCats=new Set(),allCats=[];

function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}

function setDataset(ds){
  currentDs=ds;
  Object.keys(DATASETS).forEach(k=>document.getElementById('ds-'+k).className='ds-btn'+(k===ds?' on':''));
  currentSource=DATASETS[ds];
  buildFilters();
}

function buildFilters(){
  allCats=[...new Set(currentSource.map(x=>x.cat))].sort();
  activeCats=new Set(allCats);
  const c=document.getElementById('filters');c.innerHTML='';
  const all=document.createElement('button');
  all.className='fb on';all.id='f-ALL';all.textContent='Todas';
  all.onclick=()=>toggleAll();c.appendChild(all);
  allCats.forEach(cat=>{
    const b=document.createElement('button');
    b.className='fb on';b.id='f-'+cat;b.textContent=cat;
    b.onclick=()=>toggleCat(cat);c.appendChild(b);
  });
  buildDeck(currentSource.filter(x=>activeCats.has(x.cat)));
}

function toggleAll(){
  const allOn=activeCats.size===allCats.length;
  activeCats=allOn?new Set():new Set(allCats);
  allCats.forEach(c=>{const b=document.getElementById('f-'+c);if(b)b.className='fb'+(activeCats.has(c)?' on':'');});
  document.getElementById('f-ALL').className='fb'+(activeCats.size===allCats.length?' on':'');
  buildDeck(currentSource.filter(x=>activeCats.has(x.cat)));
}
function toggleCat(cat){
  activeCats.has(cat)?activeCats.delete(cat):activeCats.add(cat);
  document.getElementById('f-'+cat).className='fb'+(activeCats.has(cat)?' on':'');
  document.getElementById('f-ALL').className='fb'+(activeCats.size===allCats.length?' on':'');
  buildDeck(currentSource.filter(x=>activeCats.has(x.cat)));
}
function buildDeck(src){
  if(!src||!src.length)return;
  deck=shuffle([...src]);idx=0;ok=0;no=0;wrong=[];
  updateStats();showCard();
  document.getElementById('done-box').style.display='none';
  document.getElementById('actions').style.display='flex';
}
function setMode(m){
  mode=m;
  ['hanzi','esp','oral'].forEach(x=>document.getElementById('m-'+x).className='mb'+(m===x?' on':''));
  showCard();
}
function showCard(){
  if(idx>=deck.length){showDone();return;}
  const c=deck[idx];flipped=false;
  document.getElementById('ci').className='card-inner';
  document.getElementById('f-cat').textContent=c.cat||'';
  if(mode==='hanzi'){
    document.getElementById('f-main').textContent=c.h;
    document.getElementById('f-main').style.fontSize='56px';
    document.getElementById('f-sub').textContent=c.p;
    document.getElementById('f-hint').textContent='Toca para ver el significado';
    document.getElementById('b-main').textContent=c.es;
    document.getElementById('b-pinyin').textContent=c.p;
    document.getElementById('b-hanzi').textContent=c.h;
  } else if(mode==='esp'){
    document.getElementById('f-main').textContent=c.es;
    document.getElementById('f-main').style.fontSize='18px';
    document.getElementById('f-sub').textContent='';
    document.getElementById('f-hint').textContent='Toca para ver el carácter';
    document.getElementById('b-main').textContent=c.h;
    document.getElementById('b-pinyin').textContent=c.p;
    document.getElementById('b-hanzi').textContent=c.es;
  } else {
    document.getElementById('f-main').textContent='🔊';
    document.getElementById('f-main').style.fontSize='52px';
    document.getElementById('f-sub').textContent='¿Qué palabra es?';
    document.getElementById('f-hint').textContent='Escucha y toca para revelar';
    document.getElementById('b-main').textContent=c.es;
    document.getElementById('b-pinyin').textContent=c.p;
    document.getElementById('b-hanzi').textContent=c.h;
  }
  const pct=Math.round(idx/deck.length*100);
  document.getElementById('prog-fill').style.width=pct+'%';
  document.getElementById('prog-label').textContent='Ficha '+(idx+1)+' de '+deck.length;
  document.getElementById('s-left').textContent=deck.length-idx;
  if(autoplay) setTimeout(()=>speakText(c.h,zhVoice,'zh-CN'),350);
}
function flip(){
  flipped=!flipped;
  document.getElementById('ci').className='card-inner'+(flipped?' flipped':'');
  if(flipped&&autoplay&&mode==='oral') setTimeout(()=>speakText(deck[idx].h,zhVoice,'zh-CN'),400);
}
function speak(lang){
  if(idx>=deck.length)return;
  const c=deck[idx];
  const u=speakText(lang==='zh'?c.h:c.es,lang==='zh'?zhVoice:esVoice,lang==='zh'?'zh-CN':'es-ES');
  const btn=document.getElementById(lang==='zh'?'btn-zh':'btn-es');
  if(btn){btn.classList.add('playing');u.onend=()=>btn.classList.remove('playing');}
}
function answer(knew){
  if(!flipped){flip();return;}
  if(knew)ok++;else{no++;wrong.push(deck[idx]);}
  idx++;updateStats();showCard();
}
function skipCard(){
  if(!flipped){flip();return;}
  wrong.push(deck[idx]);no++;idx++;updateStats();showCard();
}
function updateStats(){
  document.getElementById('s-ok').textContent=ok;
  document.getElementById('s-no').textContent=no;
  document.getElementById('s-left').textContent=Math.max(0,deck.length-idx);
}
function showDone(){
  speechSynthesis.cancel();
  document.getElementById('done-box').style.display='block';
  document.getElementById('actions').style.display='none';
  document.getElementById('prog-fill').style.width='100%';
  document.getElementById('done-msg').textContent='Sabías '+ok+' de '+deck.length+'. '+(wrong.length?'Tienes '+wrong.length+' para repasar.':'¡Perfecto! 🌟');
}
function restart(t){
  document.getElementById('done-box').style.display='none';
  document.getElementById('actions').style.display='flex';
  buildDeck(t==='wrong'&&wrong.length?wrong:currentSource.filter(x=>activeCats.has(x.cat)));
}

